{
  "name": "heif-to-jpg-workflow",
  "version": "2.0.0",
  "description": "Batch convert HEIC/HEIF photos to JPEG, preserve EXIF, strip GPS, and optionally upload to Aliyun OSS.",
  "main": "scripts/process-photos.js",
  "scripts": {
    "check": "node --check scripts/process-photos.js && node --check scripts/run-workflow.js && node --check test/process-photos.test.js && node --check test/run-workflow.test.js",
    "dry-run:photos": "node scripts/process-photos.js --dry-run",
    "process:photos": "node scripts/process-photos.js",
    "test:unit": "node --test",
    "workflow:photos": "node scripts/run-workflow.js",
    "upload:photos": "node scripts/process-photos.js --upload-only",
    "test": "npm run check && npm run test:unit"
  },
  "keywords": [
    "heic",
    "heif",
    "jpeg",
    "jpg",
    "exif",
    "oss",
    "aliyun",
    "photo-workflow"
  ],
  "author": "NeverGpDzy",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NeverGpDzy/heif-to-jpg-workflow.git"
  },
  "bugs": {
    "url": "https://github.com/NeverGpDzy/heif-to-jpg-workflow/issues"
  },
  "homepage": "https://github.com/NeverGpDzy/heif-to-jpg-workflow#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "ali-oss": "^6.23.0",
    "exiftool-vendored": "^35.18.0",
    "heic-convert": "^2.1.0"
  }
}
